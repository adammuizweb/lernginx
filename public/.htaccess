# Apache .htaccess — legacy reference only
# This project runs on Nginx. See /etc/nginx/sites-available/lernginx.lan

<FilesMatch "\.(jpg|jpeg|png|webp)$">
    Require all granted
</FilesMatch>

RewriteEngine On
RewriteBase /

# Redirect query to clean URL
RewriteCond %{QUERY_STRING} (^|&)page=([^&]+)(&|$)
RewriteRule ^$ /%2/ [R=301,L]

# Pass through existing files/directories
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Route everything else to index.php
RewriteRule ^([^/]+)/?$ index.php?page=$1 [L,QSA]
